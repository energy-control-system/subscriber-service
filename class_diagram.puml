@startuml class_diagram
skinparam monochrome true
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam classFontSize 10
skinparam packageFontSize 11
skinparam nodesep 20
skinparam ranksep 20
left to right direction

title Диаграмма классов subscriber-service

package "api" {
    class ServerBuilder {
        -server: Server
        -router: Router
        +AddSubscribers()
        +AddObjects()
        +AddContracts()
        +AddRegistry()
        +Build(): Server
    }

    class SubscriberHandler {
        +AddSubscriber()
        +GetSubscriberByID()
        +GetAllSubscribers()
    }

    class ObjectHandler {
        +AddObject()
        +GetObjectByID()
        +GetAllObjects()
    }

    class ContractHandler {
        +AddContract()
        +GetAllContracts()
        +GetLastContractByObjectID()
    }

    class RegistryHandler {
        +ParseRegistry()
    }
}

package "service" {
    class SubscriberService {
        -repository: SubscriberRepository
        +AddSubscriber()
        +GetSubscriberByID()
        +GetAllSubscribers()
    }

    class ObjectService {
        -repository: ObjectRepository
        +AddObject()
        +GetObjectByID()
        +GetAllObjects()
    }

    class ContractService {
        -repository: ContractRepository
        -taskService: TaskService
        +AddContract()
        +GetAllContracts()
        +GetLastContractByObjectID()
        +SubscriberOnInspectionEvent()
    }

    class RegistryService {
        -subscriberRepo: SubscriberRepository
        -objectRepo: ObjectRepository
        -contractRepo: ContractRepository
        +Parse()
    }

    interface SubscriberRepository {
        +AddSubscriber()
        +GetSubscriberByID()
        +GetAllSubscribers()
        +UpdateSubscriberStatus()
        +UpsertSubscribers()
    }

    interface ObjectRepository {
        +AddObject()
        +GetObjectByID()
        +GetAllObjects()
        +UpsertObjects()
        +UpsertDevices()
        +UpsertSeals()
    }

    interface ContractRepository {
        +AddContract()
        +GetAllContracts()
        +GetLastContractByObjectID()
        +UpsertContracts()
    }

    interface TaskService {
        +GetTaskByID()
    }
}

package "database" {
    class SubscriberDBRepository {
        -db: *sqlx.DB
    }

    class ObjectDBRepository {
        -db: *sqlx.DB
    }

    class ContractDBRepository {
        -db: *sqlx.DB
    }
}

package "cluster" {
    class TaskClient {
        -client: HTTPClient
        -baseURL: string
        +GetTaskByID()
    }
}

package "domain" {
    class Subscriber {
        +ID: int
        +AccountNumber: string
        +Surname: string
        +Name: string
        +PhoneNumber: string
        +Email: string
        +INN: string
        +Status: Status
        +Passport: Passport
    }

    class Passport {
        +ID: int
        +Series: string
        +Number: string
        +IssuedBy: string
        +IssueDate: string
    }

    class Object {
        +ID: int
        +Address: string
        +HaveAutomaton: bool
        +Devices: []Device
    }

    class Device {
        +ID: int
        +ObjectID: int
        +Type: string
        +Number: string
        +PlaceType: DevicePlaceType
        +Seals: []Seal
    }

    class Seal {
        +ID: int
        +DeviceID: int
        +Number: string
        +Place: string
    }

    class Contract {
        +ID: int
        +Number: string
        +SubscriberID: int
        +ObjectID: int
        +SignDate: time.Time
    }

    class Task {
        +ID: int
        +ObjectID: int
        +Status: Status
    }

    class Inspection {
        +ID: int
        +TaskID: int
        +Status: Status
        +Type: Type
        +IsViolationDetected: bool
    }

    enum Status {
        Active
        Violator
        Archived
    }

    enum DevicePlaceType {
        Other
        Flat
        StairLanding
    }
}

' API relationships
ServerBuilder --> SubscriberHandler
ServerBuilder --> ObjectHandler
ServerBuilder --> ContractHandler
ServerBuilder --> RegistryHandler

' Handler to Service
SubscriberHandler --> SubscriberService
ObjectHandler --> ObjectService
ContractHandler --> ContractService
RegistryHandler --> RegistryService

' Service to Repository
SubscriberService --> SubscriberRepository
ObjectService --> ObjectRepository
ContractService --> ContractRepository
ContractService --> TaskService
RegistryService --> SubscriberRepository
RegistryService --> ObjectRepository
RegistryService --> ContractRepository

' Repository implementations
SubscriberDBRepository ..|> SubscriberRepository
ObjectDBRepository ..|> ObjectRepository
ContractDBRepository ..|> ContractRepository
TaskClient ..|> TaskService

' Domain relationships
Subscriber *-- Passport
Subscriber --> Status
Object *-- Device
Device *-- Seal
Device --> DevicePlaceType
Contract --> Subscriber
Contract --> Object
Inspection --> Task

@enduml
